{
  "name": "remix-website",
  "version": "30.1.0",
  "private": true,
  "description": "",
  "license": "",
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "copy:assets": "node scripts/copy-assets.mjs",
    "build:css": "node scripts/ensure-build-static.mjs && postcss remix/shared/styles/site-bundle.css -o build/static/site.css && postcss remix/shared/styles/md.css -o build/static/md.css && postcss remix/shared/styles/jam.css -o build/static/jam.css",
    "build:server": "node scripts/build-server.mjs",
    "build": "pnpm run copy:assets && pnpm run build:css && pnpm run build:server",
    "dev": "pnpm run copy:assets && pnpm run build:css && tsx watch server-dev.mjs",
    "format": "prettier --write ./",
    "deploy": "flyctl deploy --build-arg REMIX_TOKEN=${REMIX_TOKEN}",
    "push:stage": "git tag -f stage && git push origin stage -f",
    "start": "cross-env NODE_ENV=production node server.mjs",
    "preview": "cross-env NODE_ENV=production node --env-file=.env server.mjs",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "test": "vitest",
    "pretest:e2e": "playwright install chromium",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@shopify/storefront-api-client": "^1.0.7",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "cssnano": "^6.0.3",
    "emoji-regex": "^10.6.0",
    "escape-goat": "^4.0.0",
    "fathom-client": "^3.7.2",
    "feed": "^4.2.2",
    "front-matter": "^4.0.2",
    "lru-cache": "^10.1.0",
    "parse-numeric-range": "^1.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remix": "github:remix-run/remix#preview/pr-11149&path:packages/remix",
    "satori": "^0.19.2",
    "semver": "^7.7.3",
    "shiki": "^0.14.7",
    "source-map-support": "^0.5.21",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.10.13",
    "@types/semver": "^7.7.1",
    "@types/source-map-support": "^0.5.10",
    "@types/unist": "^3.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.24",
    "esbuild": "^0.27.3",
    "happy-dom": "^20.6.1",
    "oxlint": "^1.50.0",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.30.1"
}
